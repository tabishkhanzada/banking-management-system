<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:controller="com.banking.frontend.controller.AdminDashboardController"
            xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@styles.css" styleClass="app-root">

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <padding><Insets top="24" right="18" bottom="22" left="18"/></padding>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="sidebar-logo" prefWidth="42" prefHeight="42">
                    <SVGPath styleClass="ico ico-white" content="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="AmaBank" styleClass="sidebar-brand"/>
                    <Label text="ADMIN CONSOLE" styleClass="sidebar-brand-sub"/>
                </VBox>
            </HBox>

            <Region prefHeight="30"/>
            <Label text="MANAGEMENT" styleClass="sidebar-section"/>
            <Region prefHeight="10"/>

            <HBox fx:id="navDashboard" styleClass="nav-item nav-item-active" alignment="CENTER_LEFT" spacing="13" onMouseClicked="#handleNavClick">
                <SVGPath styleClass="ico ico-active" content="M3 3h7v7H3z M14 3h7v7h-7z M14 14h7v7h-7z M3 14h7v7H3z" scaleX="0.82" scaleY="0.82" />
                <Label text="Dashboard"/>
            </HBox>
            <HBox fx:id="navUsers" styleClass="nav-item" alignment="CENTER_LEFT" spacing="13" onMouseClicked="#handleNavClick">
                <SVGPath styleClass="ico ico-nav" content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" scaleX="0.82" scaleY="0.82" />
                <Label text="Users"/>
            </HBox>
            <HBox fx:id="navTransactions" styleClass="nav-item" alignment="CENTER_LEFT" spacing="13" onMouseClicked="#handleNavClick">
                <SVGPath styleClass="ico ico-nav" content="M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M1 10h22" scaleX="0.82" scaleY="0.82" />
                <Label text="Transactions"/>
            </HBox>
            <HBox fx:id="navSettings" styleClass="nav-item" alignment="CENTER_LEFT" spacing="13" onMouseClicked="#handleNavClick">
                <SVGPath styleClass="ico ico-nav" content="M4 21v-7 M4 10V3 M12 21v-9 M12 8V3 M20 21v-5 M20 12V3 M1 14h6 M9 8h6 M17 16h6" scaleX="0.82" scaleY="0.82" />
                <Label text="Settings"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutButton" text="Sign Out" onAction="#handleLogout" maxWidth="Infinity" prefHeight="42"
                    contentDisplay="LEFT" graphicTextGap="10"
                    style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill: white; -fx-effect: none; -fx-border-color: rgba(255,255,255,0.18); -fx-border-width: 1.5; -fx-border-radius: 11; -fx-background-radius: 11; -fx-font-weight: bold;">
                <graphic>
                    <SVGPath styleClass="ico ico-white" content="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9" scaleX="0.72" scaleY="0.72"/>
                </graphic>
            </Button>
        </VBox>
    </left>

    <!-- ═══════════════════ MAIN ═══════════════════ -->
    <center>
        <VBox>
            <!-- topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="16" right="30" bottom="16" left="30"/></padding>
                <VBox spacing="1">
                    <Label text="Control center" styleClass="topbar-sub"/>
                    <Label fx:id="welcomeLabel" text="Admin Dashboard" styleClass="topbar-title"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="search-box" alignment="CENTER_LEFT" spacing="8" maxWidth="240">
                    <SVGPath styleClass="ico ico-muted" content="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.35-4.35" scaleX="0.66" scaleY="0.66"/>
                    <TextField promptText="Search..." HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label text="ADMINISTRATOR" styleClass="pill-admin"/>
                <StackPane styleClass="avatar" prefWidth="42" prefHeight="42">
                    <SVGPath styleClass="ico ico-white" content="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" scaleX="0.6" scaleY="0.6"/>
                </StackPane>
            </HBox>

            <!-- scrolling content -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <VBox spacing="22">
                    <padding><Insets top="24" right="30" bottom="36" left="30"/></padding>

                    <!-- ── HERO ── -->
                    <StackPane fx:id="sectionDashboard" styleClass="hero" minHeight="226">
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <padding><Insets top="30" right="30" bottom="30" left="38"/></padding>
                            <VBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label text="✦  BANKING CONTROL CENTER" styleClass="hero-eyebrow"/>
                                <Label text="Manage Your" styleClass="hero-title"/>
                                <HBox spacing="11" alignment="CENTER_LEFT">
                                    <Label text="Banking" styleClass="hero-title"/>
                                    <Label text="System" styleClass="hero-title-accent"/>
                                </HBox>
                                <Label text="Monitor accounts, transactions and approvals — all in real time."
                                       styleClass="hero-subtitle" wrapText="true" maxWidth="400"/>
                                <Region prefHeight="6"/>
                                <HBox spacing="9">
                                    <Label text="● Secure"      styleClass="hero-chip-pill"/>
                                    <Label text="● Real-time"   styleClass="hero-chip-pill"/>
                                    <Label text="● 99.9% Uptime" styleClass="hero-chip-pill"/>
                                </HBox>
                            </VBox>

                            <!-- Floating card stack -->
                            <Pane minWidth="320" prefWidth="320" maxWidth="320" minHeight="196" prefHeight="196">
                                <Region styleClass="hero-glow" prefWidth="220" prefHeight="220" layoutX="58" layoutY="-6"/>

                                <VBox fx:id="heroCardBack" styleClass="vcard-gold" prefWidth="206" prefHeight="128"
                                      rotate="-9" layoutX="20" layoutY="46">
                                    <padding><Insets top="16" right="17" bottom="16" left="17"/></padding>
                                    <Region styleClass="vcard-chip" prefWidth="38" prefHeight="29"/>
                                    <Region VBox.vgrow="ALWAYS"/>
                                    <Label text="WORLD ELITE" style="-fx-text-fill: #6B5410; -fx-font-size: 10px; -fx-font-weight: bold; -fx-font-style: italic;"/>
                                </VBox>

                                <VBox fx:id="heroCardFront" styleClass="vcard" prefWidth="222" prefHeight="138"
                                      rotate="6" layoutX="78" layoutY="22">
                                    <padding><Insets top="17" right="18" bottom="17" left="18"/></padding>
                                    <HBox alignment="CENTER_LEFT">
                                        <Region styleClass="vcard-chip" prefWidth="38" prefHeight="29"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="VISA" styleClass="vcard-brand"/>
                                    </HBox>
                                    <Region VBox.vgrow="ALWAYS"/>
                                    <Label styleClass="vcard-number" text="••••  ••••  ••••  2376"/>
                                    <Region prefHeight="9"/>
                                    <HBox alignment="BOTTOM_LEFT">
                                        <VBox spacing="2">
                                            <Label text="CARD HOLDER" styleClass="vcard-cap"/>
                                            <Label text="AMABANK ADMIN" styleClass="vcard-holder"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox spacing="2">
                                            <Label text="VALID" styleClass="vcard-cap"/>
                                            <Label text="12/29" styleClass="vcard-holder"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <Label fx:id="coin1"  text="✦" styleClass="spark"    layoutX="6"   layoutY="20"/>
                                <Label fx:id="coin2"  text="✦" styleClass="spark-sm" layoutX="300" layoutY="150"/>
                                <Label fx:id="spark1" text="✦" styleClass="spark"    layoutX="290" layoutY="8"/>
                                <Label fx:id="spark2" text="✦" styleClass="spark-sm" layoutX="36"  layoutY="168"/>
                                <Label fx:id="spark3" text="✦" styleClass="spark-sm" layoutX="170" layoutY="0"/>
                            </Pane>
                        </HBox>
                    </StackPane>

                    <!-- ── STAT CARDS ── -->
                    <HBox fx:id="statCardsRow" spacing="20">
                        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane styleClass="ico-wrap-teal">
                                    <SVGPath styleClass="ico ico-teal" content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" scaleX="0.78" scaleY="0.78"/>
                                </StackPane>
                                <Label text="Total Users" styleClass="stat-title"/>
                            </HBox>
                            <Label fx:id="statUsersLabel" text="0" styleClass="stat-num"/>
                            <Label text="Active accounts" styleClass="muted-sm"/>
                        </VBox>

                        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane styleClass="ico-wrap-blue">
                                    <SVGPath styleClass="ico ico-blue" content="M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M1 10h22" scaleX="0.78" scaleY="0.78"/>
                                </StackPane>
                                <Label text="Transactions" styleClass="stat-title"/>
                            </HBox>
                            <Label fx:id="statTransactionsLabel" text="0" styleClass="stat-num"/>
                            <Label text="All transfers" styleClass="muted-sm"/>
                        </VBox>

                        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane styleClass="ico-wrap-amber">
                                    <SVGPath styleClass="ico ico-amber" content="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M12 6v6l4 2" scaleX="0.78" scaleY="0.78"/>
                                </StackPane>
                                <Label text="Credit Requests" styleClass="stat-title"/>
                            </HBox>
                            <Label fx:id="statRequestsLabel" text="0" styleClass="stat-num"/>
                            <Label text="Pending approvals" styleClass="muted-sm"/>
                        </VBox>
                    </HBox>

                    <!-- ── ANALYTICS ── -->
                    <HBox fx:id="analyticsRow" spacing="20">
                        <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="20" right="18" bottom="10" left="18"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <SVGPath styleClass="ico ico-teal" content="M18 20V10 M12 20V4 M6 20v-6" scaleX="0.8" scaleY="0.8"/>
                                <VBox spacing="1">
                                    <Label text="Transaction Volume" styleClass="h3"/>
                                    <Label text="Monthly breakdown" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <BarChart fx:id="txBarChart" prefHeight="232" legendVisible="false" animated="true">
                                <xAxis><CategoryAxis/></xAxis>
                                <yAxis><NumberAxis/></yAxis>
                            </BarChart>
                        </VBox>

                        <VBox styleClass="card" spacing="13" prefWidth="320" minWidth="300">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <Label text="System Overview" styleClass="h3"/>
                            <HBox styleClass="ovr-row ovr-teal" alignment="CENTER_LEFT" spacing="13">
                                <SVGPath styleClass="ico ico-teal" content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" scaleX="0.7" scaleY="0.7"/>
                                <VBox spacing="2">
                                    <Label text="Total Users" styleClass="ovr-cap"/>
                                    <Label fx:id="overviewUsersLabel" text="0 active accounts" styleClass="ovr-val-teal"/>
                                </VBox>
                            </HBox>
                            <HBox styleClass="ovr-row ovr-blue" alignment="CENTER_LEFT" spacing="13">
                                <SVGPath styleClass="ico ico-blue" content="M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M1 10h22" scaleX="0.7" scaleY="0.7"/>
                                <VBox spacing="2">
                                    <Label text="Total Transactions" styleClass="ovr-cap"/>
                                    <Label fx:id="overviewTxLabel" text="0 transactions" styleClass="ovr-val-blue"/>
                                </VBox>
                            </HBox>
                            <HBox styleClass="ovr-row ovr-amber" alignment="CENTER_LEFT" spacing="13">
                                <SVGPath styleClass="ico ico-amber" content="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M12 6v6l4 2" scaleX="0.7" scaleY="0.7"/>
                                <VBox spacing="2">
                                    <Label text="Pending Requests" styleClass="ovr-cap"/>
                                    <Label fx:id="overviewRequestsLabel" text="0 pending" styleClass="ovr-val-amber"/>
                                </VBox>
                            </HBox>
                            <HBox styleClass="ovr-row ovr-red" alignment="CENTER_LEFT" spacing="13">
                                <SVGPath styleClass="ico ico-red" content="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" scaleX="0.7" scaleY="0.7"/>
                                <VBox spacing="2">
                                    <Label text="System Status" styleClass="ovr-cap"/>
                                    <Label text="All systems operational" styleClass="ovr-val-red"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ── USER MANAGEMENT ── -->
                    <VBox fx:id="sectionUsers" styleClass="card" spacing="16">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="1">
                                <Label text="User Management" styleClass="h3"/>
                                <Label text="Create, update, block and credit accounts" styleClass="muted-sm"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="refreshUsersButton" text="Refresh" onAction="#handleRefreshUsers" styleClass="btn-ghost" prefHeight="40"
                                    contentDisplay="LEFT" graphicTextGap="8">
                                <graphic><SVGPath styleClass="ico ico-ink" content="M23 4v6h-6 M1 20v-6h6 M3.51 9a9 9 0 0 1 14.85-3.36L23 10 M1 14l4.64 4.36A9 9 0 0 0 20.49 15" scaleX="0.64" scaleY="0.64"/></graphic>
                            </Button>
                        </HBox>

                        <TableView fx:id="usersTable" prefHeight="240">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="userIdColumn"   text="User ID"    prefWidth="140"/>
                                <TableColumn fx:id="usernameColumn" text="Username"   prefWidth="140"/>
                                <TableColumn fx:id="accountIdColumn" text="Account ID" prefWidth="140"/>
                                <TableColumn fx:id="balanceColumn"  text="Balance"    prefWidth="110"/>
                                <TableColumn fx:id="blockedColumn"  text="Blocked"    prefWidth="100"/>
                            </columns>
                        </TableView>

                        <HBox spacing="10">
                            <Button fx:id="createUserButton" text="Create" onAction="#handleCreateUser" styleClass="btn-primary" prefHeight="40"
                                    contentDisplay="LEFT" graphicTextGap="8">
                                <graphic><SVGPath styleClass="ico ico-white" content="M12 5v14 M5 12h14" scaleX="0.66" scaleY="0.66"/></graphic>
                            </Button>
                            <Button fx:id="editUserButton" text="Update" onAction="#handleUpdateUser" styleClass="btn-ghost" prefHeight="40"
                                    contentDisplay="LEFT" graphicTextGap="8">
                                <graphic><SVGPath styleClass="ico ico-ink" content="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7 M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4z" scaleX="0.62" scaleY="0.62"/></graphic>
                            </Button>
                            <Button fx:id="deleteUserButton" text="Delete" onAction="#handleDeleteUser" styleClass="btn-danger" prefHeight="40"
                                    contentDisplay="LEFT" graphicTextGap="8">
                                <graphic><SVGPath styleClass="ico ico-white" content="M3 6h18 M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2 M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" scaleX="0.62" scaleY="0.62"/></graphic>
                            </Button>
                            <Button fx:id="toggleBlockButton" text="Block / Unblock" onAction="#handleToggleBlock" styleClass="btn-warning" prefHeight="40"
                                    contentDisplay="LEFT" graphicTextGap="8">
                                <graphic><SVGPath content="M5 11h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1z M8 11V7a4 4 0 0 1 8 0v4" style="-fx-stroke: #4A2E05; -fx-fill: transparent; -fx-stroke-width: 2; -fx-stroke-line-cap: round; -fx-stroke-line-join: round;" scaleX="0.62" scaleY="0.62"/></graphic>
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- ── FORM + LOG (Users section) ── -->
                    <HBox fx:id="sectionUsersForm" spacing="20">
                        <VBox styleClass="card" spacing="11" HBox.hgrow="ALWAYS">
                            <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                            <Label text="Create / Edit User" styleClass="h3"/>
                            <Label text="User ID" styleClass="field-label"/>
                            <TextField fx:id="userIdField" promptText="e.g. user001" styleClass="input" prefHeight="42"/>
                            <Label text="Username" styleClass="field-label"/>
                            <TextField fx:id="usernameField" promptText="e.g. john_doe" styleClass="input" prefHeight="42"/>
                            <Label text="Password" styleClass="field-label"/>
                            <TextField fx:id="passwordField" promptText="e.g. pass123" styleClass="input" prefHeight="42"/>
                            <Label text="Account ID" styleClass="field-label"/>
                            <TextField fx:id="accountIdField" promptText="e.g. acct001" styleClass="input" prefHeight="42"/>
                            <Label text="Initial Balance" styleClass="field-label"/>
                            <TextField fx:id="initialBalanceField" promptText="0.00" styleClass="input" prefHeight="42"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="Blocked status:" styleClass="field-label"/>
                                <Label fx:id="blockedStatusLabel" text="false" styleClass="chip-active"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="card" spacing="11" HBox.hgrow="ALWAYS">
                            <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <SVGPath styleClass="ico ico-teal" content="M12 8v4l3 2 M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z" scaleX="0.74" scaleY="0.74"/>
                                <VBox spacing="1">
                                    <Label text="Activity Log" styleClass="h3"/>
                                    <Label text="Recent actions and status updates" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <TextArea fx:id="adminLogArea" editable="false" wrapText="true" prefRowCount="16" styleClass="log-area" VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </HBox>

                    <!-- ── TRANSACTIONS (visible in both Transactions and Approvals sections) ── -->
                    <HBox fx:id="sectionTransactionsAndApprovals" spacing="20">
                        <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS">
                            <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="All Transactions" styleClass="h3"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="refreshTransactionsButton" onAction="#handleRefreshTransactions" styleClass="btn-ghost" prefHeight="38">
                                    <graphic><SVGPath styleClass="ico ico-ink" content="M23 4v6h-6 M1 20v-6h6 M3.51 9a9 9 0 0 1 14.85-3.36L23 10 M1 14l4.64 4.36A9 9 0 0 0 20.49 15" scaleX="0.6" scaleY="0.6"/></graphic>
                                </Button>
                            </HBox>
                            <TableView fx:id="transactionsTable" prefHeight="240">
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="txDateColumn"        text="Date"        prefWidth="120"/>
                                    <TableColumn fx:id="txSourceColumn"      text="From"        prefWidth="110"/>
                                    <TableColumn fx:id="txDestColumn"        text="To"          prefWidth="110"/>
                                    <TableColumn fx:id="txAmountColumn"      text="Amount"      prefWidth="100"/>
                                    <TableColumn fx:id="txDescriptionColumn" text="Description" prefWidth="140"/>
                                    <TableColumn fx:id="txStatusColumn"      text="Status"      prefWidth="100"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <VBox styleClass="card" spacing="13" prefWidth="430" minWidth="380">
                            <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                            <Label text="Credit Requests" styleClass="h3"/>
                            <TableView fx:id="creditRequestsTable" prefHeight="190">
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="requestIdColumn"     text="ID"     prefWidth="130"/>
                                    <TableColumn fx:id="requestUserIdColumn" text="User"   prefWidth="110"/>
                                    <TableColumn fx:id="requestAmountColumn" text="Amount" prefWidth="100"/>
                                    <TableColumn fx:id="requestStatusColumn" text="Status" prefWidth="100"/>
                                </columns>
                            </TableView>
                            <HBox spacing="10">
                                <Button fx:id="approveRequestButton" text="Approve" onAction="#handleApproveRequest" styleClass="btn-success" prefHeight="40"
                                        contentDisplay="LEFT" graphicTextGap="8">
                                    <graphic><SVGPath styleClass="ico ico-white" content="M20 6 9 17l-5-5" scaleX="0.66" scaleY="0.66"/></graphic>
                                </Button>
                                <Button fx:id="rejectRequestButton" text="Reject" onAction="#handleRejectRequest" styleClass="btn-danger" prefHeight="40"
                                        contentDisplay="LEFT" graphicTextGap="8">
                                    <graphic><SVGPath styleClass="ico ico-white" content="M18 6 6 18 M6 6l12 12" scaleX="0.66" scaleY="0.66"/></graphic>
                                </Button>
                            </HBox>

                            <Region prefHeight="4"/>
                            <Label text="Direct Credit Account" styleClass="field-label"/>
                            <TextField fx:id="creditAccountIdField" promptText="Account ID" styleClass="input" prefHeight="42"/>
                            <HBox spacing="10">
                                <TextField fx:id="creditAmountField" promptText="Amount" styleClass="input" HBox.hgrow="ALWAYS" prefHeight="42"/>
                                <Button fx:id="creditAccountButton" text="Credit" onAction="#handleCreditAccount" styleClass="btn-success" prefHeight="42"
                                        contentDisplay="LEFT" graphicTextGap="8">
                                    <graphic><SVGPath styleClass="ico ico-white" content="M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" scaleX="0.62" scaleY="0.62"/></graphic>
                                </Button>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- ══════════════════ SETTINGS ══════════════════ -->
                    <VBox fx:id="sectionSettings" spacing="22">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <SVGPath styleClass="ico ico-teal" content="M4 21v-7 M4 10V3 M12 21v-9 M12 8V3 M20 21v-5 M20 12V3 M1 14h6 M9 8h6 M17 16h6" scaleX="0.82" scaleY="0.82"/>
                            <VBox spacing="1">
                                <Label text="Settings" styleClass="h2"/>
                                <Label text="Manage your profile, security and system preferences" styleClass="muted-sm"/>
                            </VBox>
                        </HBox>

                        <!-- Row 1: Profile + Security -->
                        <HBox spacing="20">
                            <!-- Profile -->
                            <VBox styleClass="card" spacing="13" HBox.hgrow="ALWAYS">
                                <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <StackPane styleClass="avatar" prefWidth="48" prefHeight="48">
                                        <Label text="AB" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;"/>
                                    </StackPane>
                                    <VBox spacing="1">
                                        <Label text="Administrator Profile" styleClass="h3"/>
                                        <Label text="Your account details" styleClass="muted-sm"/>
                                    </VBox>
                                </HBox>
                                <Label text="DISPLAY NAME" styleClass="label-mini"/>
                                <TextField fx:id="settingsName" text="AmaBank Admin" styleClass="input" prefHeight="42"/>
                                <Label text="EMAIL ADDRESS" styleClass="label-mini"/>
                                <TextField fx:id="settingsEmail" text="admin@amabank.com" styleClass="input" prefHeight="42"/>
                                <Label text="ROLE" styleClass="label-mini"/>
                                <HBox><Label text="SYSTEM ADMINISTRATOR" styleClass="pill-admin"/></HBox>
                                <Region prefHeight="2"/>
                                <Button text="Save Profile" onAction="#handleSaveProfile" styleClass="btn-primary" prefHeight="42" maxWidth="Infinity"/>
                            </VBox>

                            <!-- Security -->
                            <VBox styleClass="card" spacing="13" HBox.hgrow="ALWAYS">
                                <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="11">
                                    <SVGPath styleClass="ico ico-teal" content="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" scaleX="0.74" scaleY="0.74"/>
                                    <VBox spacing="1">
                                        <Label text="Security" styleClass="h3"/>
                                        <Label text="Password and access controls" styleClass="muted-sm"/>
                                    </VBox>
                                </HBox>
                                <Label text="CURRENT PASSWORD" styleClass="label-mini"/>
                                <PasswordField fx:id="settingsCurrentPw" promptText="••••••••" styleClass="input" prefHeight="42"/>
                                <Label text="NEW PASSWORD" styleClass="label-mini"/>
                                <PasswordField fx:id="settingsNewPw" promptText="Enter a new password" styleClass="input" prefHeight="42"/>
                                <CheckBox fx:id="chk2fa" text="Enable two-factor authentication" styleClass="setting-check"/>
                                <CheckBox fx:id="chkIdle" text="Require sign-out after 30 min idle" selected="true" styleClass="setting-check"/>
                                <Region prefHeight="2"/>
                                <Button text="Update Security" onAction="#handleUpdateSecurity" styleClass="btn-primary" prefHeight="42" maxWidth="Infinity"/>
                            </VBox>
                        </HBox>

                        <!-- Row 2: Preferences + System -->
                        <HBox spacing="20">
                            <!-- Preferences -->
                            <VBox styleClass="card" spacing="14" HBox.hgrow="ALWAYS">
                                <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="11">
                                    <SVGPath styleClass="ico ico-teal" content="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9 M13.73 21a2 2 0 0 1-3.46 0" scaleX="0.74" scaleY="0.74"/>
                                    <VBox spacing="1">
                                        <Label text="Preferences" styleClass="h3"/>
                                        <Label text="Notifications and display" styleClass="muted-sm"/>
                                    </VBox>
                                </HBox>
                                <CheckBox fx:id="chkEmailNotif" text="Email notifications" selected="true" styleClass="setting-check"/>
                                <CheckBox fx:id="chkTxAlerts" text="New transaction alerts" selected="true" styleClass="setting-check"/>
                                <CheckBox fx:id="chkCreditAlerts" text="Credit request alerts" selected="true" styleClass="setting-check"/>
                                <CheckBox fx:id="chkWeekly" text="Weekly summary report" styleClass="setting-check"/>
                                <Region prefHeight="4"/>
                                <Label text="DEFAULT CURRENCY" styleClass="label-mini"/>
                                <HBox spacing="8">
                                    <Label text="USD" styleClass="seg-active"/>
                                    <Label text="EUR" styleClass="seg"/>
                                    <Label text="GBP" styleClass="seg"/>
                                    <Label text="PKR" styleClass="seg"/>
                                </HBox>
                                <Region prefHeight="4"/>
                                <Button text="Save Preferences" onAction="#handleSavePreferences" styleClass="btn-ghost" prefHeight="40" maxWidth="Infinity"/>
                            </VBox>

                            <!-- System / Architecture -->
                            <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                                <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="11">
                                    <SVGPath styleClass="ico ico-teal" content="M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M1 10h22" scaleX="0.74" scaleY="0.74"/>
                                    <VBox spacing="1">
                                        <Label text="System Information" styleClass="h3"/>
                                        <Label text="Build and architecture" styleClass="muted-sm"/>
                                    </VBox>
                                </HBox>
                                <HBox styleClass="ovr-row ovr-teal" alignment="CENTER_LEFT" spacing="13">
                                    <VBox spacing="2">
                                        <Label text="Application" styleClass="ovr-cap"/>
                                        <Label text="AmaBank · v1.0.0" styleClass="ovr-val-teal"/>
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="● ONLINE" styleClass="pill-active"/>
                                </HBox>
                                <HBox styleClass="ovr-row ovr-blue" alignment="CENTER_LEFT" spacing="13">
                                    <VBox spacing="2">
                                        <Label text="Backend API" styleClass="ovr-cap"/>
                                        <Label text="http://localhost:8080" styleClass="ovr-val-blue"/>
                                    </VBox>
                                </HBox>
                                <HBox styleClass="ovr-row ovr-amber" alignment="CENTER_LEFT" spacing="13">
                                    <VBox spacing="2">
                                        <Label text="Database" styleClass="ovr-cap"/>
                                        <Label text="MySQL · Connected" styleClass="ovr-val-amber"/>
                                    </VBox>
                                </HBox>
                                <Label text="ARCHITECTURE PATTERNS" styleClass="label-mini"/>
                                <HBox spacing="7">
                                    <Label text="Singleton" styleClass="seg"/>
                                    <Label text="Factory" styleClass="seg"/>
                                    <Label text="Builder" styleClass="seg"/>
                                    <Label text="Command" styleClass="seg"/>
                                </HBox>
                                <HBox spacing="7">
                                    <Label text="Chain of Responsibility" styleClass="seg"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
