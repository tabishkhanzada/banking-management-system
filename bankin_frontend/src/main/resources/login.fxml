<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="rootPane" fx:controller="com.banking.frontend.controller.LoginController"
           xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1"
           styleClass="app-root" stylesheets="@styles.css">

    <HBox>
        <!-- ════════════ LEFT — brand panel ════════════ -->
        <StackPane styleClass="hero" HBox.hgrow="ALWAYS" minWidth="420">
            <!-- floating art -->
            <Pane mouseTransparent="true">
                <Region styleClass="hero-glow" prefWidth="260" prefHeight="260" layoutX="150" layoutY="180"/>
                <Label text="✦" styleClass="spark"    layoutX="70"  layoutY="120"/>
                <Label text="✦" styleClass="spark-sm" layoutX="380" layoutY="90"/>
                <Label text="✦" styleClass="spark"    layoutX="330" layoutY="300"/>
                <Label text="✦" styleClass="spark-sm" layoutX="110" layoutY="360"/>
            </Pane>

            <VBox spacing="0">
                <padding><Insets top="44" right="48" bottom="40" left="48"/></padding>

                <!-- brand -->
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <StackPane styleClass="sidebar-logo" prefWidth="44" prefHeight="44">
                        <SVGPath styleClass="ico ico-white" content="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/>
                    </StackPane>
                    <VBox spacing="0">
                        <Label text="AmaBank" styleClass="sidebar-brand"/>
                        <Label text="SECURE DIGITAL BANKING" styleClass="sidebar-brand-sub"/>
                    </VBox>
                </HBox>

                <Region prefHeight="40"/>

                <!-- headline -->
                <Label text="Banking," styleClass="hero-title"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="reimagined" styleClass="hero-title-accent"/>
                    <Label text="." styleClass="hero-title"/>
                </HBox>
                <Region prefHeight="14"/>
                <Label text="Move money, track spending and manage your accounts — fast, secure and beautifully simple."
                       styleClass="hero-subtitle" wrapText="true" maxWidth="360"/>

                <Region prefHeight="34"/>

                <!-- floating card -->
                <Pane prefHeight="190" maxWidth="360">
                    <VBox styleClass="vcard-gold" prefWidth="240" prefHeight="150" rotate="-7" layoutX="20" layoutY="22">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <Region styleClass="vcard-chip" prefWidth="40" prefHeight="30"/>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Label text="1234  5678  9012  2376" style="-fx-text-fill: #5C4A12; -fx-font-size: 12px; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox styleClass="vcard" prefWidth="240" prefHeight="150" rotate="6" layoutX="80" layoutY="6">
                        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                        <HBox alignment="CENTER_LEFT">
                            <Region styleClass="vcard-chip" prefWidth="40" prefHeight="30"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="VISA" styleClass="vcard-brand"/>
                        </HBox>
                        <Region VBox.vgrow="ALWAYS"/>
                        <Label styleClass="vcard-number" text="•••• •••• •••• 2376"/>
                        <Region prefHeight="8"/>
                        <Label text="AKHTAR FAREED" styleClass="vcard-holder"/>
                    </VBox>
                </Pane>

                <Region VBox.vgrow="ALWAYS"/>
            </VBox>
        </StackPane>

        <!-- ════════════ RIGHT — sign in ════════════ -->
        <StackPane minWidth="440" prefWidth="460" style="-fx-background-color: #FFFFFF;">
            <VBox fx:id="formBox" spacing="0" alignment="CENTER_LEFT" maxWidth="340">
                <Label text="Welcome back" styleClass="h1"/>
                <Region prefHeight="6"/>
                <Label text="Sign in to your account to continue" styleClass="muted"/>

                <Region prefHeight="30"/>

                <Label text="USERNAME" styleClass="label-mini"/>
                <Region prefHeight="7"/>
                <StackPane>
                    <TextField fx:id="usernameField" promptText="Enter your username" prefHeight="50"
                               styleClass="input" style="-fx-padding: 11 14 11 44;"/>
                    <SVGPath styleClass="ico ico-muted" content="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"
                             mouseTransparent="true" scaleX="0.72" scaleY="0.72" StackPane.alignment="CENTER_LEFT" translateX="14"/>
                </StackPane>

                <Region prefHeight="16"/>

                <Label text="PASSWORD" styleClass="label-mini"/>
                <Region prefHeight="7"/>
                <StackPane>
                    <PasswordField fx:id="passwordField" promptText="Enter your password" prefHeight="50"
                                   styleClass="input" style="-fx-padding: 11 14 11 44;"/>
                    <SVGPath styleClass="ico ico-muted" content="M5 11h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8a1 1 0 0 1 1-1z M8 11V7a4 4 0 0 1 8 0v4"
                             mouseTransparent="true" scaleX="0.72" scaleY="0.72" StackPane.alignment="CENTER_LEFT" translateX="14"/>
                </StackPane>

                <Region prefHeight="24"/>

                <Button fx:id="loginButton" text="Sign In  →" onAction="#handleLogin"
                        styleClass="btn-primary" maxWidth="Infinity" prefHeight="50"
                        style="-fx-font-size: 14px;"/>

                <Label fx:id="statusLabel" wrapText="true" maxWidth="Infinity" alignment="CENTER"
                       style="-fx-text-fill: #EF4444; -fx-font-size: 12px; -fx-padding: 10 0 0 0;"/>

                <Region prefHeight="22"/>

                <!-- demo creds -->
                <VBox styleClass="card" spacing="6" maxWidth="Infinity">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="DEMO CREDENTIALS" styleClass="label-mini"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Admin" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px; -fx-min-width: 56;"/>
                        <Label text="admin / admin" style="-fx-text-fill: #0F1B2D; -fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Consolas', monospace;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="User" style="-fx-text-fill: #94A3B8; -fx-font-size: 12px; -fx-min-width: 56;"/>
                        <Label text="ahsan / ahsan" style="-fx-text-fill: #0F1B2D; -fx-font-size: 12px; -fx-font-weight: bold; -fx-font-family: 'Consolas', monospace;"/>
                    </HBox>
                </VBox>

                <Region prefHeight="18"/>
                <Label text="© 2025 AmaBank · All rights reserved" style="-fx-text-fill: #CBD5E1; -fx-font-size: 10px;"
                       maxWidth="Infinity" alignment="CENTER"/>
            </VBox>
        </StackPane>
    </HBox>
</StackPane>
