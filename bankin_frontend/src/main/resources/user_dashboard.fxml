<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:controller="com.banking.frontend.controller.UserDashboardController"
            xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@styles.css" styleClass="app-root">

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
    <left>
        <VBox styleClass="sidebar" spacing="0">
            <padding><Insets top="24" right="18" bottom="22" left="18"/></padding>

            <!-- brand -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="sidebar-logo" prefWidth="42" prefHeight="42">
                    <SVGPath styleClass="ico ico-white" content="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="AmaBank" styleClass="sidebar-brand"/>
                    <Label text="PERSONAL BANKING" styleClass="sidebar-brand-sub"/>
                </VBox>
            </HBox>

            <Region prefHeight="30"/>
            <Label text="MENU" styleClass="sidebar-section"/>
            <Region prefHeight="10"/>

            <HBox styleClass="nav-item nav-item-active" alignment="CENTER_LEFT" spacing="13">
                <SVGPath styleClass="ico ico-active" content="M3 3h7v7H3z M14 3h7v7h-7z M14 14h7v7h-7z M3 14h7v7H3z" scaleX="0.82" scaleY="0.82"/>
                <Label text="Dashboard"/>
            </HBox>
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="13">
                <SVGPath styleClass="ico ico-nav" content="M22 2 11 13 M22 2l-7 20-4-9-9-4z" scaleX="0.82" scaleY="0.82"/>
                <Label text="Transfers"/>
            </HBox>
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="13">
                <SVGPath styleClass="ico ico-nav" content="M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M1 10h22" scaleX="0.82" scaleY="0.82"/>
                <Label text="My Cards"/>
            </HBox>
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="13">
                <SVGPath styleClass="ico ico-nav" content="M18 20V10 M12 20V4 M6 20v-6" scaleX="0.82" scaleY="0.82"/>
                <Label text="Analytics"/>
            </HBox>
            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="13">
                <SVGPath styleClass="ico ico-nav" content="M4 21v-7 M4 10V3 M12 21v-9 M12 8V3 M20 21v-5 M20 12V3 M1 14h6 M9 8h6 M17 16h6" scaleX="0.82" scaleY="0.82"/>
                <Label text="Settings"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="logoutButton" text="Sign Out" onAction="#handleLogout" maxWidth="Infinity" prefHeight="42"
                    contentDisplay="LEFT" graphicTextGap="10"
                    style="-fx-background-color: rgba(255,255,255,0.10); -fx-text-fill: white; -fx-effect: none; -fx-border-color: rgba(255,255,255,0.18); -fx-border-width: 1.5; -fx-border-radius: 11; -fx-background-radius: 11; -fx-font-weight: bold;">
                <graphic>
                    <SVGPath styleClass="ico ico-white" content="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9" scaleX="0.72" scaleY="0.72"/>
                </graphic>
            </Button>
        </VBox>
    </left>

    <!-- ═══════════════════ MAIN ═══════════════════ -->
    <center>
        <VBox>
            <!-- topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="16" right="30" bottom="16" left="30"/></padding>
                <VBox spacing="1">
                    <Label text="Welcome back" styleClass="topbar-sub"/>
                    <Label fx:id="welcomeLabel" text="User Dashboard" styleClass="topbar-title"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox styleClass="search-box" alignment="CENTER_LEFT" spacing="8" maxWidth="240">
                    <SVGPath styleClass="ico ico-muted" content="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.35-4.35" scaleX="0.66" scaleY="0.66"/>
                    <TextField promptText="Search..." HBox.hgrow="ALWAYS"/>
                </HBox>
                <StackPane styleClass="icon-btn" prefWidth="40" prefHeight="40">
                    <SVGPath styleClass="ico ico-ink" content="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9 M13.73 21a2 2 0 0 1-3.46 0" scaleX="0.66" scaleY="0.66"/>
                </StackPane>
                <Label text="● ACTIVE" styleClass="pill-active"/>
                <StackPane styleClass="avatar" prefWidth="42" prefHeight="42">
                    <SVGPath styleClass="ico ico-white" content="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" scaleX="0.62" scaleY="0.62"/>
                </StackPane>
            </HBox>

            <!-- scrolling content -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
                <VBox spacing="22">
                    <padding><Insets top="24" right="30" bottom="36" left="30"/></padding>

                    <!-- ── HERO ── -->
                    <StackPane fx:id="heroBanner" styleClass="hero" minHeight="216">
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <padding><Insets top="28" right="28" bottom="28" left="34"/></padding>

                            <VBox spacing="9" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label text="TOTAL BALANCE" styleClass="hero-balance-cap"/>
                                <Label fx:id="balanceLabel" text="\$0.00" styleClass="hero-balance"/>
                                <Label fx:id="heroAcctLabel" text="•••• •••• •••• ····" styleClass="hero-acct"/>
                                <Region prefHeight="6"/>
                                <HBox spacing="10">
                                    <Label text="✓  Active" styleClass="hero-chip-pill"/>
                                    <Label fx:id="accountChip" text="Account" styleClass="hero-chip-pill"/>
                                </HBox>
                            </VBox>

                            <!-- drawn cards + sparkles -->
                            <Pane minWidth="330" prefWidth="330" maxWidth="330" minHeight="200" prefHeight="200">
                                <Region styleClass="hero-glow" prefWidth="190" prefHeight="190" layoutX="80" layoutY="20"/>

                                <VBox fx:id="heroCardBack" styleClass="vcard-gold" prefWidth="200" prefHeight="124"
                                      rotate="-8" layoutX="28" layoutY="40">
                                    <padding><Insets top="15" right="16" bottom="15" left="16"/></padding>
                                    <Region styleClass="vcard-chip" prefWidth="36" prefHeight="27"/>
                                    <Region VBox.vgrow="ALWAYS"/>
                                    <Label text="1234  5678  9012" style="-fx-text-fill: #5C4A12; -fx-font-size: 11px; -fx-font-family: 'Consolas', monospace; -fx-font-weight: bold;"/>
                                </VBox>

                                <VBox fx:id="mainCard" styleClass="vcard" prefWidth="212" prefHeight="132"
                                      rotate="5" layoutX="80" layoutY="20">
                                    <padding><Insets top="16" right="17" bottom="16" left="17"/></padding>
                                    <HBox alignment="CENTER_LEFT">
                                        <Region styleClass="vcard-chip" prefWidth="36" prefHeight="27"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="VISA" styleClass="vcard-brand"/>
                                    </HBox>
                                    <Region VBox.vgrow="ALWAYS"/>
                                    <Label fx:id="cardNumberLabel" styleClass="vcard-number" text="•••• •••• •••• 2376"/>
                                    <Region prefHeight="9"/>
                                    <HBox alignment="BOTTOM_LEFT">
                                        <VBox spacing="2">
                                            <Label text="CARD HOLDER" styleClass="vcard-cap"/>
                                            <Label fx:id="cardHolderLabel" text="ACCOUNT HOLDER" styleClass="vcard-holder"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <VBox spacing="2">
                                            <Label text="VALID" styleClass="vcard-cap"/>
                                            <Label text="12/29" styleClass="vcard-holder"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <Label fx:id="coin1" text="✦" styleClass="spark"    layoutX="8"   layoutY="14"/>
                                <Label fx:id="coin2" text="✦" styleClass="spark-sm" layoutX="296" layoutY="120"/>
                                <Label fx:id="spark1" text="✦" styleClass="spark"    layoutX="272" layoutY="6"/>
                                <Label fx:id="spark2" text="✦" styleClass="spark-sm" layoutX="40"  layoutY="156"/>
                                <Label fx:id="spark3" text="✦" styleClass="spark"    layoutX="306" layoutY="66"/>
                            </Pane>
                        </HBox>
                    </StackPane>

                    <!-- ── STAT CARDS ── -->
                    <HBox fx:id="statCardsRow" spacing="20">
                        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane styleClass="ico-wrap-teal">
                                    <SVGPath styleClass="ico ico-teal" content="M17 7 7 17 M17 17H7V7" scaleX="0.82" scaleY="0.82"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Credits Received" styleClass="stat-title"/>
                                    <Label text="Incoming" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="totalCreditLabel" text="\$0.00" styleClass="stat-num"/>
                            <Label text="Received into your account" styleClass="stat-up"/>
                        </VBox>

                        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane styleClass="ico-wrap-red">
                                    <SVGPath styleClass="ico ico-red" content="M7 17 17 7 M7 7h10v10" scaleX="0.82" scaleY="0.82"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Transfers Sent" styleClass="stat-title"/>
                                    <Label text="Outgoing" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="totalDebitLabel" text="\$0.00" styleClass="stat-num"/>
                            <Label text="Sent from your account" styleClass="stat-down"/>
                        </VBox>

                        <VBox styleClass="stat-card" spacing="12" HBox.hgrow="ALWAYS">
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <StackPane styleClass="ico-wrap-amber">
                                    <SVGPath styleClass="ico ico-amber" content="M18 20V10 M12 20V4 M6 20v-6" scaleX="0.82" scaleY="0.82"/>
                                </StackPane>
                                <VBox spacing="1">
                                    <Label text="Transactions" styleClass="stat-title"/>
                                    <Label text="On this account" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <Label fx:id="txCountLabel" text="0" styleClass="stat-num"/>
                            <Label text="Total recorded" styleClass="stat-up"/>
                        </VBox>
                    </HBox>

                    <!-- ── CHARTS ── -->
                    <HBox fx:id="chartsRow" spacing="20">
                        <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                            <padding><Insets top="20" right="18" bottom="10" left="18"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <SVGPath styleClass="ico ico-teal" content="M23 6l-9.5 9.5-5-5L1 18 M17 6h6v6" scaleX="0.8" scaleY="0.8"/>
                                <VBox spacing="1">
                                    <Label text="Balance Trend" styleClass="h3"/>
                                    <Label text="Last 6 months" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <AreaChart fx:id="balanceTrendChart" prefHeight="248" legendVisible="false" animated="true">
                                <xAxis><CategoryAxis/></xAxis>
                                <yAxis><NumberAxis tickLabelGap="4"/></yAxis>
                            </AreaChart>
                        </VBox>

                        <VBox styleClass="card" spacing="8" prefWidth="320" minWidth="300">
                            <padding><Insets top="20" right="18" bottom="10" left="18"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <SVGPath styleClass="ico ico-teal" content="M21.21 15.89A10 10 0 1 1 8 2.83 M22 12A10 10 0 0 0 12 2v10z" scaleX="0.8" scaleY="0.8"/>
                                <VBox spacing="1">
                                    <Label text="Transaction Split" styleClass="h3"/>
                                    <Label text="Credits vs Transfers" styleClass="muted-sm"/>
                                </VBox>
                            </HBox>
                            <PieChart fx:id="transactionPieChart" prefHeight="248" legendVisible="true" labelsVisible="false" animated="true"/>
                        </VBox>
                    </HBox>

                    <!-- ── QUICK ACTIONS ── -->
                    <HBox fx:id="cardRow" spacing="20">
                        <VBox styleClass="card" spacing="16" HBox.hgrow="ALWAYS">
                            <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <SVGPath styleClass="ico ico-teal" content="M13 2 3 14h9l-1 8 10-12h-9z" scaleX="0.8" scaleY="0.8"/>
                                <Label text="Quick Actions" styleClass="h3"/>
                            </HBox>

                            <HBox spacing="24">
                                <!-- send money -->
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="SEND MONEY" styleClass="label-mini"/>
                                    <TextField fx:id="destinationAccountField" promptText="Destination account ID" styleClass="input" prefHeight="46"/>
                                    <TextField fx:id="amountField" promptText="Amount  (e.g. 500.00)" styleClass="input" prefHeight="46"/>
                                    <Button fx:id="transferButton" text="Transfer Money" onAction="#handleTransfer"
                                            styleClass="btn-primary" maxWidth="Infinity" prefHeight="46"
                                            contentDisplay="LEFT" graphicTextGap="9">
                                        <graphic><SVGPath styleClass="ico ico-white" content="M22 2 11 13 M22 2l-7 20-4-9-9-4z" scaleX="0.72" scaleY="0.72"/></graphic>
                                    </Button>
                                </VBox>

                                <Region style="-fx-background-color: #ECEFF4;" prefWidth="1" maxWidth="1"/>

                                <!-- request credit -->
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="REQUEST CREDIT" styleClass="label-mini"/>
                                    <TextField fx:id="creditAmountField" promptText="Credit amount  (e.g. 1000.00)" styleClass="input" prefHeight="46"/>
                                    <Region prefHeight="46"/>
                                    <Button fx:id="requestCreditButton" text="Request Credit" onAction="#handleRequestCredit"
                                            styleClass="btn-gold" maxWidth="Infinity" prefHeight="46"
                                            contentDisplay="LEFT" graphicTextGap="9">
                                        <graphic><SVGPath content="M12 5v14 M5 12h14" style="-fx-stroke: #4A3A0A; -fx-fill: transparent; -fx-stroke-width: 2.2; -fx-stroke-line-cap: round;" scaleX="0.72" scaleY="0.72"/></graphic>
                                    </Button>
                                </VBox>
                            </HBox>
                            <Label fx:id="transferStatusLabel" wrapText="true" style="-fx-text-fill: #EF4444; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>

                    <!-- ── TRANSACTIONS ── -->
                    <VBox fx:id="txCard" styleClass="card" spacing="14">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <SVGPath styleClass="ico ico-teal" content="M2 5h20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M1 10h22" scaleX="0.74" scaleY="0.74"/>
                            <Label text="Recent Transactions" styleClass="h3"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="accountFilterField" promptText="Filter by account..." styleClass="input" prefHeight="38" prefWidth="200"/>
                            <Button fx:id="filterTransactionsButton" onAction="#handleFilterTransactions" styleClass="btn-ghost" prefHeight="38">
                                <graphic><SVGPath styleClass="ico ico-ink" content="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z M21 21l-4.35-4.35" scaleX="0.66" scaleY="0.66"/></graphic>
                            </Button>
                            <Button fx:id="clearFilterButton" onAction="#handleClearFilter" styleClass="btn-ghost" prefHeight="38">
                                <graphic><SVGPath styleClass="ico ico-ink" content="M18 6 6 18 M6 6l12 12" scaleX="0.66" scaleY="0.66"/></graphic>
                            </Button>
                        </HBox>
                        <TableView fx:id="transactionTable" prefHeight="264">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="dateColumn"        text="Date"   prefWidth="200"/>
                                <TableColumn fx:id="typeColumn"        text="Type"   prefWidth="120"/>
                                <TableColumn fx:id="amountColumn"      text="Amount" prefWidth="130"/>
                                <TableColumn fx:id="descriptionColumn" text="Status" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- ── CREDIT REQUESTS ── -->
                    <VBox fx:id="creditReqCard" styleClass="card" spacing="14">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <SVGPath styleClass="ico ico-teal" content="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M12 6v6l4 2" scaleX="0.74" scaleY="0.74"/>
                            <Label text="My Credit Requests" styleClass="h3"/>
                        </HBox>
                        <TableView fx:id="creditRequestsTable" prefHeight="180">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="requestIdColumn"        text="Request ID" prefWidth="200"/>
                                <TableColumn fx:id="requestAccountIdColumn" text="Account"    prefWidth="150"/>
                                <TableColumn fx:id="requestAmountColumn"    text="Amount"     prefWidth="130"/>
                                <TableColumn fx:id="requestStatusColumn"    text="Status"     prefWidth="140"/>
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
